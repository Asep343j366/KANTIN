# Supabase — ambil dari Project Settings > API di dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key (RAHASIA — hanya dipakai di server, jangan pakai prefix NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Kredensial login admin (email & password akun admin di Supabase Auth)
# Buat user admin lewat dashboard Supabase > Authentication > Users

# Casaku — QRIS dinamis + auto-verifikasi (RAHASIA — server-only, tanpa NEXT_PUBLIC)
# Semua nilai dari Dashboard Casaku (https://casaku.id)
CASAKU_LICENSE_KEY=xxxxxxxx          # halaman API Keys
CASAKU_QR_ID=00000000-0000-0000-0000-000000000000  # ID QRIS Merchant (UUID) yang terdaftar
CASAKU_WEBHOOK_SECRET=xxxxxxxx       # Webhook Secret (untuk verifikasi HMAC-SHA256)
CASAKU_PACKAGE_IDS=id.dana           # package id aplikasi penerima, pisah koma (cth: id.dana,com.shopee.id)
CASAKU_BASE_URL=https://api.casaku.id
